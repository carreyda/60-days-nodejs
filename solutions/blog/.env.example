# 复制为 .env（和这份 docker-compose.yml 同目录）后按需修改。
# `docker compose` 会自动读取同目录的 .env，把下面的变量插值进 docker-compose.yml。
# `.env` 不提交（见 .gitignore）。

# ── 必填：JWT 签名密钥 ───────────────────────────────────────────────────
# 镜像硬编码 NODE_ENV=production，config.validation.ts 会拒绝 .env.example 里的占位示例值
# （防止示例 secret 被带上线）。生成一个强随机串：
#   openssl rand -base64 32
JWT_ACCESS_SECRET=请替换成-openssl-rand-base64-32-生成的强随机串-至少32字符

# ── 可选：覆盖默认值 ─────────────────────────────────────────────────────
# 数据库密码（要和 POSTGRES_PASSWORD 一致——compose 里 PG 建库和 api/migrate 连库共用它）
POSTGRES_PASSWORD=blog_dev_pwd
# api 对宿主机暴露的端口（默认 3000）
API_PORT=3000
